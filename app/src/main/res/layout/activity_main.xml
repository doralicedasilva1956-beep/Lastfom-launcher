<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Título Principal -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="@string/welcome_title"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Área Central: Configurações de Perfil e Login -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Campo para digitar o Nome (Login Offline) -->
        <EditText
            android:id="@+id/edtUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2C2C2C"
            android:hint="@string/hint_username"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <!-- Botão para Importar o APK do Jogo -->
        <Button
            android:id="@+id/btnImport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#4A4A4A"
            android:text="@string/btn_import_apk"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <!-- Texto de Status do APK -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_no_apk"
            android:textColor="#FF5555"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Botão JOGAR na Parte Inferior -->
    <Button
        android:id="@+id/btnPlay"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#388E3C"
        android:text="@string/btn_play"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</RelativeLayout>
